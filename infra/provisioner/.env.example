L1_RPC_URL="http://localhost:8545"
L1_CHAIN_ID="31337"
REGISTRY_ADDRESS="0x0000000000000000000000000000000000dEaD"
PROVISIONER_PRIVATE_KEY="0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a"
POLL_INTERVAL_MS="6000"
CONFIRMATIONS="2"
DATABASE_URL="postgresql://vampchains:vampchains@localhost:5432/vampchains"

# Block-signing key baked into every vampchain node this provisioner
# creates — same key reused across every chain by design (public info,
# it doesn't custody funds, see docs/ARCHITECTURE.md). This example value
# is just a placeholder well-known test key.
CLIQUE_SIGNER_PRIVATE_KEY="0x47e179ec197488593b187f80a00eb0da91f1b9d0b13f8733639f19c30a34926a"

# local-docker | fly
PROVISION_BACKEND="local-docker"
SIDECHAIN_IMAGE="vampchains-sidechain-node:latest"
DOCKER_NETWORK="vampchains_default"
LOCAL_HOST_PORT_BASE="8600"

# only needed when PROVISION_BACKEND=fly
FLY_API_TOKEN=""
FLY_ORG_SLUG=""
FLY_REGION="iad"
