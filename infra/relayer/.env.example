L1_RPC_URL="http://localhost:8545"
L1_CHAIN_ID="31337"
BRIDGE_ADDRESS="0x0000000000000000000000000000000000dEaD"
# Pure signing key — never submits a transaction, never needs ETH. Must
# match the `signer` address configured on VampBridge.
RELAYER_PRIVATE_KEY="0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d"
# Spends the treasury account's pre-funded native currency on each
# vampchain to mint deposits. Real signed transactions now (geth, not
# anvil) but only ever on the vampchain itself — never touches L1, never
# needs L1 gas. This example value is just a placeholder well-known test
# key, NOT the real treasury key used on any deployed chain.
TREASURY_PRIVATE_KEY="0x7c852118294e51e653712a81e05800f419141751be58f605c371e15141b007a6"
POLL_INTERVAL_MS="4000"
CONFIRMATIONS="2"
# The withdrawal-signal address on every vampchain — sending native
# currency here signals "I want to withdraw." Defaults to the treasury
# account itself (recaptured, not destroyed) if unset.
BURN_ADDRESS="0x12f5B89B02C8107278c5F24E74d7B44267C55d1f"
DATABASE_URL="postgresql://vampchains:vampchains@localhost:5432/vampchains"
