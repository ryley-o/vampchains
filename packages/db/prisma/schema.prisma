// vampchains off-chain index. Source of truth is always the on-chain
// contracts (VampChainRegistry, VampBridge) — everything here is a cache the
// indexer/provisioner/relayer keep in sync, never authoritative on its own.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChainStatus {
  PENDING_PROVISION // ChainCreated seen on-chain, infra not up yet
  PROVISIONING // Fly machine being created
  ACTIVE // node up and serving RPC
  DEACTIVATING // registry says depleted, teardown in progress
  DEACTIVATED // torn down, terminal state
  PROVISION_FAILED // needs human attention
}

enum FundingEventKind {
  CREATED
  TOPUP
  WITHDRAWAL
}

/// One row per vampchain, keyed by the registry's on-chain chainId.
model Chain {
  id          Int    @id @default(autoincrement())
  chainId     BigInt @unique // VampChainRegistry chainId
  evmChainId  BigInt @unique // this vampchain's own EVM chain id

  baseToken         String
  baseTokenName     String
  baseTokenSymbol   String
  baseTokenDecimals Int

  name    String
  symbol  String
  creator String

  status     ChainStatus @default(PENDING_PROVISION)
  flyAppName String?
  rpcUrl     String? // internal (Fly 6PN) RPC URL, e.g. http://<app>.internal:8545

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deposits      DepositEvent[]
  withdrawals   WithdrawalEvent[]
  fundingEvents FundingEvent[]
  wrappedTokens WrappedToken[]

  @@index([status])
  @@index([baseToken])
}

/// L1 VampBridge.Deposited events, and whether the relayer has minted the
/// corresponding balance on the vampchain yet.
model DepositEvent {
  id      Int   @id @default(autoincrement())
  chain   Chain @relation(fields: [chainDbId], references: [id])
  chainDbId Int
  chainId BigInt

  txHash      String
  logIndex    Int
  blockNumber BigInt
  nonce       BigInt

  from      String
  recipient String
  amount    String // uint256 as decimal string

  /// Null for the chain's own base token (native-currency minting path).
  /// Set to the L1 token address for general ERC20 deposits (wrapped-token
  /// minting path) — see VampBridge.depositToken / docs/ARCHITECTURE.md
  /// "General ERC20 bridging".
  token String?

  mintedAt DateTime?

  createdAt DateTime @default(now())

  @@unique([txHash, logIndex])
  @@index([chainId])
  @@index([mintedAt])
}

/// Sidechain burns the relayer has observed. `signature` is the EIP-712
/// claim signature once the relayer has produced it — infra/rpc-gateway
/// serves it to the frontend, which submits it to VampBridge.claim() via
/// the user's own wallet (they pay the L1 gas, not us). We don't currently
/// index the resulting on-chain Claimed event back into claimTxHash/claimedAt
/// (the contract's `claimed(sidechainTxHash)` is the source of truth for
/// whether a claim has actually happened) — those columns are reserved for
/// if/when that gets built.
model WithdrawalEvent {
  id      Int   @id @default(autoincrement())
  chain   Chain @relation(fields: [chainDbId], references: [id])
  chainDbId Int
  chainId BigInt

  sidechainTxHash String @unique
  sidechainBlock  BigInt

  to     String
  amount String // uint256 as decimal string, in the base token's own decimals

  /// Null for the chain's own base token (native-currency recapture path,
  /// VampBridge.claim). Set to the L1 token address for general ERC20
  /// withdrawals (VampBridge.claimToken) — see docs/ARCHITECTURE.md
  /// "General ERC20 bridging".
  token String?

  signature String? // EIP-712 claim signature, set once the relayer has signed

  claimTxHash String?
  claimedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([chainId])
  @@index([claimedAt])
}

/// One row per (chain, L1 token) pair that's ever been general-bridged —
/// i.e. every wrapped token VampWrappedTokenFactory has deployed on a given
/// vampchain. The on-chain factory is the real source of truth (its
/// deterministic address formula works with no index at all — see
/// docs/ARCHITECTURE.md), but the relayer and web app both need to
/// enumerate "which tokens has this chain wrapped" without re-deriving that
/// from raw L1 event history every time, so this is a cache the relayer
/// keeps in sync as it deploys/mints.
model WrappedToken {
  id        Int   @id @default(autoincrement())
  chain     Chain @relation(fields: [chainDbId], references: [id])
  chainDbId Int
  chainId   BigInt

  l1Token  String // the token's address on the home chain (L1)
  wrapped  String // its deterministic CREATE2 clone address on the vampchain
  name     String
  symbol   String
  decimals Int

  createdAt DateTime @default(now())

  @@unique([chainDbId, l1Token])
  @@index([chainId])
}

/// Registry-level funding history (chain creation, top-ups, protocol
/// withdrawals) — powers the public "funding balance / runway" UI.
model FundingEvent {
  id      Int   @id @default(autoincrement())
  chain   Chain @relation(fields: [chainDbId], references: [id])
  chainDbId Int
  chainId BigInt

  kind        FundingEventKind
  amount      String // uint256 as decimal string
  actor       String
  txHash      String
  blockNumber BigInt

  createdAt DateTime @default(now())

  @@unique([txHash, chainId, kind])
  @@index([chainId])
}

/// Last processed block per on-chain watcher, so the indexer/relayer can
/// resume after a restart without re-scanning from genesis or double-processing.
model IndexerCursor {
  id        String   @id // e.g. "registry", "bridge-deposits", "bridge-releases"
  lastBlock BigInt
  updatedAt DateTime @updatedAt
}
