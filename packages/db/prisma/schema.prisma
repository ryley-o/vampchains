// vampchains off-chain index. Source of truth is always the on-chain
// contracts (VampChainRegistry, VampBridge) — everything here is a cache the
// indexer/provisioner/relayer keep in sync, never authoritative on its own.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChainStatus {
  PENDING_PROVISION // ChainCreated seen on-chain, infra not up yet
  PROVISIONING // Fly machine being created
  ACTIVE // node up and serving RPC
  AWAITING_SNAPSHOT // registry's grace period expired; node stays up just
  // long enough to read final balances and publish a snapshot Merkle root
  // on VampBridge — see docs/ARCHITECTURE.md "Protocol fee revenue" /
  // snapshot claims. The public rpc-gateway already stops serving this
  // chain once status leaves ACTIVE, even though the Fly machine is still
  // briefly alive for this internal read.
  DEACTIVATING // snapshot published, infra backup + teardown in progress
  DEACTIVATED // torn down, terminal state — funds remain claimable via the
  // snapshot for SNAPSHOT_CLAIM_WINDOW, then sweepable by the protocol
  PROVISION_FAILED // needs human attention
}

enum FundingEventKind {
  CREATED
  TOPUP
  WITHDRAWAL
}

enum WithdrawalKind {
  USER // a real user's own withdrawal (VampBridge.claim/claimToken)
  FEE_SWEEP // protocol-swept tip revenue from the shared Clique signer
  // address, split 50/50 with the chain's creator (VampBridge.claimSwept)
  // — see docs/ARCHITECTURE.md "Protocol fee revenue".
}

/// One row per vampchain, keyed by the registry's on-chain chainId.
model Chain {
  id          Int    @id @default(autoincrement())
  chainId     BigInt @unique // VampChainRegistry chainId
  evmChainId  BigInt @unique // this vampchain's own EVM chain id

  baseToken         String
  baseTokenName     String
  baseTokenSymbol   String
  baseTokenDecimals Int

  name    String
  symbol  String
  creator String

  status     ChainStatus @default(PENDING_PROVISION)
  flyAppName String?
  rpcUrl     String? // internal (Fly 6PN) RPC URL, e.g. http://<app>.internal:8545

  /// Running EIP-1559 base-fee-burn accounting for this chain — see
  /// docs/ARCHITECTURE.md "Protocol fee revenue" and VampBridge.claimBurnedFees.
  /// `cumulativeBaseFeeBurnedNativeWei` is the exact running total of
  /// `baseFeePerGas * gasUsed` summed over every block up to
  /// `baseFeeScanBlock`, in native 18-decimal wei — kept as the precise
  /// source of truth so scaling down to the base token's own raw decimal
  /// units (`cumulativeBaseFeeBurned`, what the on-chain claim actually
  /// uses) is always computed fresh from the full total, never compounded
  /// tick over tick, which would otherwise let per-tick rounding dust add
  /// up over time. `baseFeeAttestationSignature` is always a signature over
  /// the *current* `cumulativeBaseFeeBurned`, refreshed whenever it changes
  /// — infra/rpc-gateway serves it at `/fees/:chainId`.
  cumulativeBaseFeeBurnedNativeWei String    @default("0")
  cumulativeBaseFeeBurned          String    @default("0")
  baseFeeScanBlock                 BigInt    @default(0)
  baseFeeAttestedAt                DateTime?
  baseFeeAttestationSignature      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deposits             DepositEvent[]
  withdrawals          WithdrawalEvent[]
  fundingEvents        FundingEvent[]
  wrappedTokens        WrappedToken[]
  snapshotEntitlements SnapshotEntitlement[]

  @@index([status])
  @@index([baseToken])
}

/// L1 VampBridge.Deposited events, and whether the relayer has minted the
/// corresponding balance on the vampchain yet.
model DepositEvent {
  id      Int   @id @default(autoincrement())
  chain   Chain @relation(fields: [chainDbId], references: [id])
  chainDbId Int
  chainId BigInt

  txHash      String
  logIndex    Int
  blockNumber BigInt
  nonce       BigInt

  from      String
  recipient String
  amount    String // uint256 as decimal string

  /// Null for the chain's own base token (native-currency minting path).
  /// Set to the L1 token address for general ERC20 deposits (wrapped-token
  /// minting path) — see VampBridge.depositToken / docs/ARCHITECTURE.md
  /// "General ERC20 bridging".
  token String?

  mintedAt DateTime?

  createdAt DateTime @default(now())

  @@unique([txHash, logIndex])
  @@index([chainId])
  @@index([mintedAt])
}

/// Sidechain burns the relayer has observed. `signature` is the EIP-712
/// claim signature once the relayer has produced it — infra/rpc-gateway
/// serves it to the frontend, which submits it to VampBridge.claim() via
/// the user's own wallet (they pay the L1 gas, not us). We don't currently
/// index the resulting on-chain Claimed event back into claimTxHash/claimedAt
/// (the contract's `claimed(sidechainTxHash)` is the source of truth for
/// whether a claim has actually happened) — those columns are reserved for
/// if/when that gets built.
model WithdrawalEvent {
  id      Int   @id @default(autoincrement())
  chain   Chain @relation(fields: [chainDbId], references: [id])
  chainDbId Int
  chainId BigInt

  sidechainTxHash String @unique
  sidechainBlock  BigInt

  to     String
  amount String // uint256 as decimal string, in the base token's own decimals

  /// Null for the chain's own base token (native-currency recapture path,
  /// VampBridge.claim). Set to the L1 token address for general ERC20
  /// withdrawals (VampBridge.claimToken) — see docs/ARCHITECTURE.md
  /// "General ERC20 bridging".
  token String?

  /// USER (default) means this row is a real withdrawal signed for
  /// `claim`/`claimToken`. FEE_SWEEP means the burn came from the shared
  /// Clique signer/etherbase address (swept tip revenue) and is signed for
  /// `claimSwept` instead — see withdrawalWatcher.ts and
  /// docs/ARCHITECTURE.md "Protocol fee revenue". `to` is meaningless for a
  /// FEE_SWEEP row (claimSwept ignores it and splits 50/50 on-chain
  /// instead); kept populated anyway since it's just whatever address the
  /// sweep burn happened to come from.
  kind WithdrawalKind @default(USER)

  signature String? // EIP-712 claim signature, set once the relayer has signed

  claimTxHash String?
  claimedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([chainId])
  @@index([claimedAt])
}

/// One row per (chain, L1 token) pair that's ever been general-bridged —
/// i.e. every wrapped token VampWrappedTokenFactory has deployed on a given
/// vampchain. The on-chain factory is the real source of truth (its
/// deterministic address formula works with no index at all — see
/// docs/ARCHITECTURE.md), but the relayer and web app both need to
/// enumerate "which tokens has this chain wrapped" without re-deriving that
/// from raw L1 event history every time, so this is a cache the relayer
/// keeps in sync as it deploys/mints.
model WrappedToken {
  id        Int   @id @default(autoincrement())
  chain     Chain @relation(fields: [chainDbId], references: [id])
  chainDbId Int
  chainId   BigInt

  l1Token  String // the token's address on the home chain (L1)
  wrapped  String // its deterministic CREATE2 clone address on the vampchain
  name     String
  symbol   String
  decimals Int

  createdAt DateTime @default(now())

  @@unique([chainDbId, l1Token])
  @@index([chainId])
}

/// One row per (chain, token, holder) leaf in a published snapshot Merkle
/// tree (see VampBridge.publishSnapshot/claimSnapshot) — built once by the
/// provisioner from a chain's final on-chain balances right as its grace
/// period expires. The chain contract only ever stores the root; this
/// table is what lets the frontend look up "does this address have
/// anything to claim" and fetch the actual Merkle proof to submit, since
/// proofs aren't derivable from a root alone. `claimed`/`claimedAt` are a
/// best-effort cache for UI purposes only — `VampBridge.snapshotClaimed`
/// on chain is the real source of truth for whether a claim has happened.
model SnapshotEntitlement {
  id        Int   @id @default(autoincrement())
  chain     Chain @relation(fields: [chainDbId], references: [id])
  chainDbId Int
  chainId   BigInt

  /// The zero address for the chain's own base token (native-currency
  /// path), or the L1 token address for a general-bridged wrapped token —
  /// matches claimSnapshot's `token` parameter exactly (including how it
  /// represents "native"). Deliberately NOT nullable, unlike `token` on
  /// DepositEvent/WithdrawalEvent: this column is part of the compound
  /// unique index below, and Postgres never treats two NULLs as equal in a
  /// unique constraint — a nullable column here would silently let
  /// duplicate native-path rows through for the same holder.
  token   String
  address String
  amount  String // uint256 as decimal string
  proof   String // JSON-encoded bytes32[] array, in the exact order claimSnapshot expects

  claimed   Boolean   @default(false)
  claimedAt DateTime?

  createdAt DateTime @default(now())

  @@unique([chainDbId, token, address])
  @@index([chainId])
  @@index([address])
}

/// Registry-level funding history (chain creation, top-ups, protocol
/// withdrawals) — powers the public "funding balance / runway" UI.
model FundingEvent {
  id      Int   @id @default(autoincrement())
  chain   Chain @relation(fields: [chainDbId], references: [id])
  chainDbId Int
  chainId BigInt

  kind        FundingEventKind
  amount      String // uint256 as decimal string
  actor       String
  txHash      String
  blockNumber BigInt

  createdAt DateTime @default(now())

  @@unique([txHash, chainId, kind])
  @@index([chainId])
}

/// Last processed block per on-chain watcher, so the indexer/relayer can
/// resume after a restart without re-scanning from genesis or double-processing.
model IndexerCursor {
  id        String   @id // e.g. "registry", "bridge-deposits", "bridge-releases"
  lastBlock BigInt
  updatedAt DateTime @updatedAt
}
