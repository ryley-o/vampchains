# Contract addresses per home chain (from `forge script script/Deploy.s.sol`
# output on each) — one full group per home chain in @vampchains/chains.
# Any group left unset just shows that home chain as "coming soon" on the
# site rather than crashing; see contracts.ts for why these must stay
# literal `process.env.NEXT_PUBLIC_X` property accesses.
NEXT_PUBLIC_BASE_REGISTRY_ADDRESS=""
NEXT_PUBLIC_BASE_BRIDGE_ADDRESS=""
NEXT_PUBLIC_BASE_USDC_ADDRESS=""
NEXT_PUBLIC_BASE_USDC_DECIMALS="6"
NEXT_PUBLIC_BASE_L1_RPC_URL=""

NEXT_PUBLIC_ETHEREUM_REGISTRY_ADDRESS=""
NEXT_PUBLIC_ETHEREUM_BRIDGE_ADDRESS=""
NEXT_PUBLIC_ETHEREUM_USDC_ADDRESS=""
NEXT_PUBLIC_ETHEREUM_USDC_DECIMALS="6"
NEXT_PUBLIC_ETHEREUM_L1_RPC_URL=""

NEXT_PUBLIC_ROBINHOOD_REGISTRY_ADDRESS=""
NEXT_PUBLIC_ROBINHOOD_BRIDGE_ADDRESS=""
NEXT_PUBLIC_ROBINHOOD_USDC_ADDRESS=""
NEXT_PUBLIC_ROBINHOOD_USDC_DECIMALS="6"
NEXT_PUBLIC_ROBINHOOD_L1_RPC_URL=""

# infra/rpc-gateway's public URL (shared across all home chains — the
# gateway routes by evmChainId, not home chain)
NEXT_PUBLIC_GATEWAY_URL="http://localhost:18080"

# Postgres (shared with @vampchains/db)
DATABASE_URL="postgresql://vampchains:vampchains@localhost:5432/vampchains"
